matrix.nelyah.eu {
	import security_headers
	import geo_allow_eu_and_na
	# import rate_limit_site synapse_global 1000 1m

	# Matrix media uploads can be up to 50MB
	request_body {
		max_size 50MB
	}

	reverse_proxy http://synapse.synapse.svc.cluster.local
}

nelyah.eu {
	# Matrix federation delegation
	header /.well-known/matrix/* Content-Type application/json
	header /.well-known/matrix/* Access-Control-Allow-Origin *
	respond /.well-known/matrix/server `{"m.server": "matrix.nelyah.eu:443"}`
	respond /.well-known/matrix/client `{"m.homeserver": {"base_url": "https://matrix.nelyah.eu"}}`

	# Reject all other requests
	respond * "Not Found" 404 {
		close
	}
}
